---
    const { width, rotate, ...props } = Astro.props;
---

<svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 300 300"
    class:list={['icon', 'dots', { rotate }]}
    aria-hidden="true"
    width={width}
    {...props}
>
    <g>
        <circle cx="20" cy="20" r="15"></circle>
        <circle cx="20" cy="55" r="15"></circle>
        <circle cx="20" cy="90" r="15"></circle>
        <circle cx="20" cy="125" r="15"></circle>
        <circle cx="20" cy="160" r="15"></circle>
        <circle cx="20" cy="195" r="15"></circle>
        <circle cx="20" cy="230" r="15"></circle>
        <circle cx="20" cy="265" r="15"></circle>

        <circle cx="57" cy="20" r="13"></circle>
        <circle cx="57" cy="55" r="13"></circle>
        <circle cx="57" cy="90" r="13"></circle>
        <circle cx="57" cy="125" r="13"></circle>
        <circle cx="57" cy="160" r="13"></circle>
        <circle cx="57" cy="195" r="13"></circle>
        <circle cx="57" cy="230" r="13"></circle>
        <circle cx="57" cy="265" r="13"></circle>

        <circle cx="94" cy="20" r="11"></circle>
        <circle cx="94" cy="55" r="11"></circle>
        <circle cx="94" cy="90" r="11"></circle>
        <circle cx="94" cy="125" r="11"></circle>
        <circle cx="94" cy="160" r="11"></circle>
        <circle cx="94" cy="195" r="11"></circle>
        <circle cx="94" cy="230" r="11"></circle>

        <circle cx="131" cy="55" r="9"></circle>
        <circle cx="131" cy="90" r="9"></circle>
        <circle cx="131" cy="125" r="9"></circle>
        <circle cx="131" cy="160" r="9"></circle>
        <circle cx="131" cy="195" r="9"></circle>
        <circle cx="131" cy="230" r="9"></circle>

        <circle cx="168" cy="55" r="7"></circle>
        <circle cx="168" cy="90" r="7"></circle>
        <circle cx="168" cy="125" r="7"></circle>
        <circle cx="168" cy="160" r="7"></circle>
        <circle cx="168" cy="195" r="7"></circle>

        <circle cx="205" cy="90" r="5"></circle>
        <circle cx="205" cy="160" r="5"></circle>
        <circle cx="205" cy="195" r="5"></circle>

        <circle cx="242" cy="160" r="2"></circle>
    </g>
</svg>

<style>
    .icon {
        display: block;
    }

    .dots {
        fill: var(--accent-clr);
        opacity: 0.2;
    }

    .rotate {
        transform: rotate(180deg);
    }
</style>
