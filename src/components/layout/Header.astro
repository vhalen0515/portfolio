---
import Logo from '../../assets/logos/Logo.astro';
import Day from '../../assets/icons/Day.astro';
import Night from '../../assets/icons/Night.astro';
---

<header class="header">
    <!-- Mobile -->
    <div class="mobile-header">
        <a
            class="logo"
            href="https://www.trent-avilla.com/"
            aria-label="Go to homepage"
        >
            <Logo size={52} />
        </a>
        <button
            id="theme-btn-mobile"
            class="theme-btn theme-btn-mobile"
            aria-label="Switch theme"
        >
            <span class="icon-dark"><Night width={25} height={25} /></span>
            <span class="icon-light" style="display:none"
                ><Day width={28} height={28} /></span
            >
        </button>
        <button
            id="hamburger"
            class="hamburger"
            aria-controls="mobile-menu"
            aria-expanded="false"
            aria-label="Open menu"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <!-- Desktop -->
    <div class="desktop-header">
        <!-- <a
            class="fade logo"
            style="--fade-delay: 0s"
            href="/"
            aria-label="Go to homepage"
        > -->
        <a
            class="logo"
            href="/"
            aria-label="Go to homepage"
        >
            <Logo size={52} />
        </a>
        <nav class="desktop-nav">
            <ul>
                <li
                    class="reveal"
                    style="--reveal-y: -24px; --reveal-delay: 0s"
                >
                    <a href="#about">About</a>
                </li>
                <li
                    class="reveal"
                    style="--reveal-y: -24px; --reveal-delay: 0.1s"
                >
                    <a href="#experience">Experience</a>
                </li>
                <li
                    class="reveal"
                    style="--reveal-y: -24px; --reveal-delay: 0.2s"
                >
                    <a href="#projects">Projects</a>
                </li>
                <li
                    class="reveal"
                    style="--reveal-y: -24px; --reveal-delay: 0.3s"
                >
                    <a href="#contact">Contact</a>
                </li>
            </ul>
        </nav>
        <button
            id="theme-btn-desktop"
            class="theme-btn"
            aria-label="Switch theme"
        >
            <div class="reveal" style="--reveal-y: -24px; --reveal-delay: 0.4s">
                <span class="icon-dark"><Night width={15} height={15} /></span>
                <span class="icon-light" style="display:none"
                    ><Day width={18} height={18} /></span
                >
            </div>
        </button>
    </div>
</header>

<!-- Mobile menu popout -->
<nav id="mobile-menu" class="mobile-nav" aria-label="Mobile navigation" inert>
    <div class="menu-backdrop" aria-hidden="true"></div>
    <ul>
        <li>
            <a class="mobile-nav-link" href="#about">About</a>
        </li>
        <li>
            <a class="mobile-nav-link" href="#experience">Experience</a>
        </li>
        <li>
            <a class="mobile-nav-link" href="#projects">Projects</a>
        </li>
        <li>
            <a class="mobile-nav-link" href="#contact">Contact</a>
        </li>
    </ul>
</nav>

