---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

import LeftSidebar from '../components/layout/LeftSidebar.astro';
import RightSidebar from '../components/layout/RightSidebar.astro';

import '../styles/global.css';

const {
    title = 'Trent Avilla – Front-End Developer & Portfolio',
    description = "Trent Avilla's portfolio showcasing web development projects, past projects, and front-end design skills.",
    showSidebars = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />

        <!-- Title -->
        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- Favicon -->
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon-dark.svg"
            media="(prefers-color-scheme: dark)"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon-light.svg"
            media="(prefers-color-scheme: light)"
        />

        <!-- Preload fonts -->
        <link
            rel="preload"
            href="/fonts/Montserrat-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Reddit-Mono.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <!-- Theme init: must run before paint -->
        <script is:inline>
            const theme = localStorage.getItem('theme') ?? 'light';
            document.documentElement.setAttribute('data-theme', theme);
        </script>
    </head>
    <body>
        <Header />
        {
            showSidebars && (
                <div id="sidebar-wrapper">
                    <LeftSidebar />
                    <RightSidebar />
                </div>
            )
        }
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>

<style>
    @media (height < 400px) {
        #sidebar-wrapper {
            display: none;
        }
    }
</style>

<script>
    requestAnimationFrame(() => {
        document
            .querySelectorAll(
                'header .reveal, header .fade, .left-sidebar, .right-sidebar'
            )
            .forEach((el) => {
                el.classList.add('is-visible');
            });
    });
</script>
